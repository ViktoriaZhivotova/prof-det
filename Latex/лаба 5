\begin{frame}{Основание и становление (1931--1932)}
    \begin{columns}
        \begin{column}{0.6\textwidth}
            \begin{itemize}
                \item \textbf{5 августа 1931 г.} — распоряжение о создании индустриально-педагогического института в Орле.
                \item \textbf{16 октября 1931 г.} — начало занятий на физико-техническом факультете.
                \item \textbf{1932 г.} — преобразование в физико-математический факультет (физмат).
                \item Первый декан — \textbf{Трофим Ильич Поподько}.
            \end{itemize}
        \end{column}
