\begin{frame}{Научное наследие и гордость факультета}
    \begin{itemize}
        \item \textbf{Игорь Аркадьевич Струков} — разработка космических платформ для изучения «черных дыр».
        \item \textbf{Геннадий Андреевич Зюганов} — выпускник 1969 года, секретарь комитета комсомола.
        \item \textbf{Федор Степанович Авдеев} — выпускник физмата, многолетний ректор университета.
